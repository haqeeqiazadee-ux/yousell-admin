{
  "name": "yousell-admin",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:phase1": "vitest run tests/phase1-supabase.test.ts",
    "test:phase2": "vitest run tests/phase2-api-smoke.test.ts",
    "test:phase3": "vitest run tests/phase3-business-logic.test.ts",
    "test:phase4": "vitest run tests/phase4-new-features.test.ts",
    "test:phase5": "vitest run tests/phase5-security.test.ts",
    "test:unit": "vitest run tests/phase3-business-logic.test.ts tests/phase5-security.test.ts",
    "test:integration": "vitest run tests/phase1-supabase.test.ts tests/phase2-api-smoke.test.ts tests/phase4-new-features.test.ts",
    "preflight": "npx tsc --noEmit && next lint",
    "e2e": "npx playwright test",
    "e2e:auth": "npx playwright test auth-flows",
    "e2e:visual": "npx playwright test visual-regression",
    "e2e:admin": "npx playwright test admin-dashboard",
    "e2e:update-snapshots": "npx playwright test --update-snapshots",
    "e2e:report": "npx playwright show-report e2e-report"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@supabase/ssr": "^0.9.0",
    "autoprefixer": "^10.4.27",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next": "^15.3.0",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.8",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^3.8.0",
    "server-only": "^0.0.1",
    "sonner": "^1.3.1",
    "stripe": "^20.4.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.1",
    "@supabase/supabase-js": "^2.99.1",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "dotenv": "^17.3.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.3.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.0"
  }
}
