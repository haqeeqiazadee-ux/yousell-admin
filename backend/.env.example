# =============================================================
# YOUSELL BACKEND — Environment Variables (Railway)
# =============================================================

# Server
PORT=3001
CORS_ALLOWED_ORIGINS=https://admin.yousell.online,https://yousell.online
FRONTEND_URL=https://admin.yousell.online

# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=xxx

# Redis (Railway auto-provides REDIS_URL)
REDIS_URL=redis://localhost:6379

# Frontend ↔ Backend shared secret
BACKEND_API_KEY=xxx

# AI
ANTHROPIC_API_KEY=xxx

# Scraping
APIFY_API_TOKEN=xxx

# Email
RESEND_API_KEY=xxx
RESEND_FROM=YouSell <noreply@yousell.online>
ADMIN_EMAIL=admin@yousell.online

# Payments
SQUARE_ACCESS_TOKEN=xxx
SQUARE_ENVIRONMENT=sandbox
SQUARE_LOCATION_ID=xxx

# Provider selection
TIKTOK_PROVIDER=apify
AMAZON_PROVIDER=apify_rapidapi
SUPPLIER_PROVIDER=apify

# Meta Ads (for ad intelligence engine)
META_ACCESS_TOKEN=xxx

# Feature flags (all disabled by default — manual-first)
POD_DISCOVERY_ENABLED=false
POD_PROVISION_ENABLED=false
POD_SYNC_ENABLED=false
SHOPIFY_PUSH_ENABLED=false
SHOPIFY_CONTENT_PUSH_ENABLED=false
AYRSHARE_ENABLED=false
