          <mxGeometry x="530" y="1130" width="170" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="f1-e14" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="f1-score" target="f1-tier" parent="1"/>

