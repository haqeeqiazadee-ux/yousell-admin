  </diagram>

  <!-- PAGE 10: ENGINE EXTRACTION PATTERN — How to spin off any engine -->
  <diagram id="flow10-extraction" name="10. Engine Extraction Pattern">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1100">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="f10-title" value="Engine Extraction Pattern — How to Spin Off Any Engine as Standalone SaaS" style="text;html=1;fontSize=20;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="250" y="20" width="700" height="35" as="geometry"/>
        </mxCell>

        <!-- Before: Embedded -->
        <mxCell id="f10-before-label" value="BEFORE: Engine Inside YOUSELL Monolith" style="text;html=1;fontSize=14;fontStyle=1;fillColor=#FFCDD2;strokeColor=#C62828;rounded=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="100" y="80" width="500" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="f10-mono" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C62828;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="130" width="500" height="350" as="geometry"/>
        </mxCell>
        <mxCell id="f10-mono-label" value="YOUSELL Platform" style="text;html=1;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="260" y="135" width="140" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="f10-eng-inside" value="Engine N&#xa;(e.g. CreatorMatch)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#4527A0;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="240" y="180" width="170" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="f10-api-in" value="/api/engine/influencers/*" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#D1C4E9;strokeColor=#4527A0;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="220" y="245" width="210" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="f10-data-in" value="Own Tables:&#xa;influencers, influencer_scores" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=8;fillColor=#D1C4E9;strokeColor=#4527A0;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="140" y="290" width="180" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="f10-queue-in" value="Own Queue:&#xa;influencer-refresh" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#D1C4E9;strokeColor=#4527A0;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="340" y="295" width="140" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="f10-bus-in" value="Event Bus" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F44336;strokeColor=#B71C1C;fontColor=#FFF;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="360" width="250" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="f10-pub-in" value="Publishes:&#xa;influencer.matched" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="140" y="400" width="130" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="f10-sub-in" value="Subscribes:&#xa;score.tier_changed" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFECB3;strokeColor=#FF8F00;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="290" y="400" width="130" height="30" as="geometry"/>
        </mxCell>

        <!-- Arrow -->
        <mxCell id="f10-arrow" value="EXTRACT" style="text;html=1;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="630" y="280" width="120" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="f10-arrow-line" value="" style="endArrow=block;html=1;strokeWidth=3;strokeColor=#2E7D32;endFill=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="630" y="300" as="sourcePoint"/>
            <mxPoint x="770" y="300" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- After: Standalone -->
        <mxCell id="f10-after-label" value="AFTER: Standalone SaaS (&quot;CreatorMatch&quot;)" style="text;html=1;fontSize=14;fontStyle=1;fillColor=#C8E6C9;strokeColor=#2E7D32;rounded=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="780" y="80" width="500" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="f10-standalone" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="780" y="130" width="500" height="350" as="geometry"/>
        </mxCell>
        <mxCell id="f10-standalone-label" value="CreatorMatch SaaS (Standalone Deploy)" style="text;html=1;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="870" y="135" width="300" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="f10-eng-out" value="CreatorMatch Engine&#xa;(Same code, own deploy)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#4527A0;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="920" y="180" width="190" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="f10-api-out" value="Public API:&#xa;api.creatormatch.com/v1/*" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#D1C4E9;strokeColor=#4527A0;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="900" y="245" width="210" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="f10-data-out" value="Own Database:&#xa;(Supabase or Postgres)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=8;fillColor=#D1C4E9;strokeColor=#4527A0;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="810" y="295" width="160" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="f10-queue-out" value="Own Queue:&#xa;(BullMQ or SQS)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#D1C4E9;strokeColor=#4527A0;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1000" y="300" width="140" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="f10-webhook-out" value="Webhook Endpoints&#xa;(Replace Event Bus Subscriptions)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFECB3;strokeColor=#FF8F00;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="850" y="365" width="250" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="f10-callout" value="Webhook Callouts&#xa;(Replace Event Bus Publishes)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="850" y="410" width="250" height="30" as="geometry"/>
        </mxCell>

        <!-- 5-Step Extraction Process -->
        <mxCell id="f10-steps-title" value="5-Step Engine Extraction Process" style="text;html=1;fontSize=16;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="300" y="520" width="600" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="f10-step1" value="1. COPY&#xa;Engine's API routes,&#xa;workers, and lib code" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="570" width="180" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="f10-step2" value="2. MIGRATE&#xa;Engine's owned tables&#xa;to own database" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="320" y="570" width="180" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="f10-step3" value="3. REPLACE&#xa;Event subscriptions →&#xa;webhook endpoints" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="540" y="570" width="180" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="f10-step4" value="4. REPLACE&#xa;Event publishes →&#xa;webhook callouts" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#4527A0;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="760" y="570" width="180" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="f10-step5" value="5. DEPLOY&#xa;Independently.&#xa;Zero changes needed&#xa;in remaining YOUSELL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#C62828;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="980" y="570" width="200" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="f10-se1" value="" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#666;endFill=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="280" y="600" as="sourcePoint"/>
            <mxPoint x="320" y="600" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="f10-se2" value="" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#666;endFill=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="500" y="600" as="sourcePoint"/>
            <mxPoint x="540" y="600" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="f10-se3" value="" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#666;endFill=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="720" y="600" as="sourcePoint"/>
            <mxPoint x="760" y="600" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="f10-se4" value="" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#666;endFill=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="940" y="600" as="sourcePoint"/>
            <mxPoint x="980" y="600" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Data isolation guarantee -->
        <mxCell id="f10-guarantee" value="DATA ISOLATION GUARANTEE:&#xa;Each engine ONLY reads/writes its own tables. Cross-engine data access goes through the Event Bus.&#xa;This means extracting an engine never requires schema changes in any other engine's tables." style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#FFFDE7;strokeColor=#999;fontSize=11;fontStyle=0;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="250" y="670" width="700" height="70" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

