        <mxCell id="eb-dep-flow" value="Discovery (1)&#xa;→ product.discovered&#xa;→ Trend Scout (2) + Data Fusion (3) + Competitor (10)&#xa;→ data.merged&#xa;→ Scoring (4) [+ POD Scoring (5) if POD]&#xa;→ score.completed&#xa;→ Profitability (6) + Financial (7) + Influencer (8) + Supplier (9) + Blueprint (12)&#xa;→ enrichment events&#xa;→ Allocation (13) [Admin approves]&#xa;→ product.allocated&#xa;→ Shop Connect (16) + Creative Studio (14) + Automation (21)&#xa;→ content.generated&#xa;→ Smart Publisher (15)&#xa;→ shop.product_pushed&#xa;→ Order Tracking (17)&#xa;→ order.received&#xa;→ Affiliate Engine (19) [auto-tracks commissions]" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666;fontSize=10;align=left;spacingLeft=15;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="200" y="810" width="1400" height="220" as="geometry"/>
        </mxCell>

