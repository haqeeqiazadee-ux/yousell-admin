        <mxCell id="ea-apify" value="Apify Cloud&#xa;(Scraping Runtime)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
