        <mxCell id="eb-dep-title" value="Inter-Engine Event Flow (All via Event Bus — No Direct Coupling)" style="text;html=1;fontSize=16;fontStyle=1;align=center;fillColor=#F5F5F5;strokeColor=#666;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="760" width="2100" height="30" as="geometry"/>
