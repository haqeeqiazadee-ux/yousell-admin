          <mxGeometry x="720" y="1095" width="150" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="ea-redis" value="Redis / BullMQ&#xa;(Queue Broker)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="720" y="1145" width="150" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="ea-eventbus" value="Event Bus&#xa;(Supabase Realtime&#xa;or Redis Pub/Sub)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="720" y="1195" width="150" height="45" as="geometry"/>
