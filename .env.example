# =============================================================
# YOUSELL PLATFORM — Environment Variables
# =============================================================
# Copy to .env.local and fill in your values.
# Never commit .env.local to git.

# -------------------------------------------------------------
# Supabase (Required)
# -------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxx
SUPABASE_SERVICE_ROLE_KEY=xxx

# -------------------------------------------------------------
# Site URL (Required for OAuth redirects & Stripe callbacks)
# -------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://admin.yousell.online

# -------------------------------------------------------------
# Stripe (Required for billing)
# -------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# -------------------------------------------------------------
# AI / Anthropic (Required for content generation & insights)
# -------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxx

# -------------------------------------------------------------
# Apify (Required for scraping — primary data source)
# -------------------------------------------------------------
APIFY_API_KEY=apify_api_xxx

# -------------------------------------------------------------
# Email (Required for transactional emails)
# -------------------------------------------------------------
RESEND_API_KEY=re_xxx
FROM_EMAIL=noreply@yousell.online
ADMIN_EMAIL=admin@yousell.online

# -------------------------------------------------------------
# Scraping API Keys (Optional — fallbacks if Apify unavailable)
# -------------------------------------------------------------
TIKTOK_API_KEY=xxx
AMAZON_API_KEY=xxx
SHOPIFY_SCRAPER_KEY=xxx
PINTEREST_API_KEY=xxx
RAPIDAPI_KEY=xxx

# -------------------------------------------------------------
# OAuth — Store Integrations (Required for channel connections)
# -------------------------------------------------------------
# Shopify
SHOPIFY_CLIENT_ID=xxx
SHOPIFY_CLIENT_SECRET=xxx

# TikTok Shop
TIKTOK_CLIENT_KEY=xxx
TIKTOK_CLIENT_SECRET=xxx

# Amazon SP-API
AMAZON_SP_CLIENT_ID=xxx
AMAZON_SP_CLIENT_SECRET=xxx

# -------------------------------------------------------------
# Backend / Workers (Railway)
# -------------------------------------------------------------
SUPABASE_URL=https://xxx.supabase.co
REDIS_URL=redis://localhost:6379
PORT=4000
FRONTEND_URL=https://admin.yousell.online
