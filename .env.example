# =============================================================
# YOUSELL PLATFORM — Environment Variables
# =============================================================
# Copy to .env.local and fill in your values.
# Never commit .env.local to git.

# -------------------------------------------------------------
# Supabase (Required)
# -------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxx
SUPABASE_SERVICE_ROLE_KEY=xxx

# -------------------------------------------------------------
# Site URLs (Required for OAuth redirects & payment callbacks)
# -------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://yousell.online
NEXT_PUBLIC_ADMIN_URL=https://admin.yousell.online
NEXT_PUBLIC_BACKEND_URL=https://your-railway-app.up.railway.app

# -------------------------------------------------------------
# Square (Required for billing — replaces Stripe)
# -------------------------------------------------------------
SQUARE_ACCESS_TOKEN=xxx
SQUARE_ENVIRONMENT=sandbox
SQUARE_LOCATION_ID=xxx
SQUARE_WEBHOOK_SIGNATURE_KEY=xxx

# -------------------------------------------------------------
# AI / Anthropic (Required for content generation & insights)
# -------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxx

# -------------------------------------------------------------
# Apify (Required for scraping — primary data source)
# -------------------------------------------------------------
APIFY_API_TOKEN=apify_api_xxx

# -------------------------------------------------------------
# Email (Required for transactional emails)
# -------------------------------------------------------------
RESEND_API_KEY=re_xxx
FROM_EMAIL=noreply@yousell.online
ADMIN_EMAIL=admin@yousell.online

# -------------------------------------------------------------
# Scraping API Keys (Optional — fallbacks if Apify unavailable)
# -------------------------------------------------------------
TIKTOK_API_KEY=xxx
AMAZON_API_KEY=xxx
SHOPIFY_SCRAPER_KEY=xxx
PINTEREST_API_KEY=xxx
RAPIDAPI_KEY=xxx

# -------------------------------------------------------------
# OAuth — Store Integrations (Required for channel connections)
# -------------------------------------------------------------
# Shopify
SHOPIFY_CLIENT_ID=xxx
SHOPIFY_CLIENT_SECRET=xxx

# TikTok Shop
TIKTOK_CLIENT_KEY=xxx
TIKTOK_CLIENT_SECRET=xxx

# Amazon SP-API
AMAZON_SP_CLIENT_ID=xxx
AMAZON_SP_CLIENT_SECRET=xxx

# -------------------------------------------------------------
# Webhook Secrets
# -------------------------------------------------------------
SHOPIFY_WEBHOOK_SECRET=xxx
TIKTOK_WEBHOOK_SECRET=xxx
AMAZON_WEBHOOK_SECRET=xxx

# -------------------------------------------------------------
# Provider Selection (controls scraper backends)
# -------------------------------------------------------------
TIKTOK_PROVIDER=apify
AMAZON_PROVIDER=apify_rapidapi
INFLUENCER_PROVIDER=ainfluencer
SUPPLIER_PROVIDER=apify
SHOPIFY_PROVIDER=apify
PINTEREST_PROVIDER=apify
TRENDS_PROVIDER=pytrends
GOOGLE_TRENDS_PROVIDER=pytrends

# -------------------------------------------------------------
# Backend ↔ Frontend shared secret
# -------------------------------------------------------------
BACKEND_API_KEY=xxx

# -------------------------------------------------------------
# Backend / Workers (Railway)
# -------------------------------------------------------------
SUPABASE_URL=https://xxx.supabase.co
REDIS_URL=redis://localhost:6379
PORT=3001
FRONTEND_URL=https://admin.yousell.online
CORS_ALLOWED_ORIGINS=https://admin.yousell.online,https://yousell.online
